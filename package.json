{
  "name": "preflight",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@expo-google-fonts/barlow": "^0.4.1",
    "@expo-google-fonts/barlow-semi-condensed": "^0.4.1",
    "@expo/vector-icons": "^15.0.2",
    "@sanity/client": "^7.23.0",
    "@sanity/image-url": "^2.1.1",
    "expo": "~57.0.4",
    "expo-asset": "~57.0.3",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.0",
    "expo-dev-client": "~57.0.5",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.0",
    "ts-fsrs": "^5.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "agent-browser": "^0.27.0",
    "jest": "^29.7.0",
    "jest-expo": "^57.0.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "content:validate": "node scripts/content/validate-content.mjs",
    "content:extract": "python3 scripts/content/extract_phak.py",
    "studio": "npm --prefix studio run dev",
    "studio:deploy-schema": "npm --prefix studio run schema:deploy"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/*.test.ts",
      "**/*.test.tsx"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/studio/"
    ]
  },
  "private": true
}
